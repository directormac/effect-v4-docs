{
  "name": "effect-v4-docs",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=8192' astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "docgen": "bun --cwd effect docgen && node scripts/copy-docs.mjs && node scripts/ai-docgen.mjs",
    "ai-docgen": "node scripts/ai-docgen.mjs",
    "generate-types": "wrangler types",
    "deploy": "astro build && wrangler pages deploy",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.0.1",
    "@astrojs/starlight": "^0.41.1",
    "@catppuccin/starlight": "^2.0.1",
    "astro": "^7.0.2",
    "sharp": "^0.34.5",
    "starlight-changelogs": "^0.5.0"
  },
  "devDependencies": {
    "wrangler": "^4.105.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": ">=1.3.11",
      "onFail": "download"
    }
  }
}
